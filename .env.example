# === Email Alerts (optional) ===
# To receive email warnings when projected usage is high,
# fill in your Gmail credentials below. Get an App Password at:
# https://myaccount.google.com/apppasswords
#
# Leave these blank to use the menu bar monitor without email alerts.
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
ALERT_RECIPIENT=your-email@gmail.com

# === Threshold Settings ===
# These thresholds apply to the PROJECTED 7-day usage at reset time.
# The actual usage % comes directly from Anthropic's API.
#
# Projected % that triggers a WARNING email
WARNING_THRESHOLD=90
# Projected % that triggers an ALARM email
ALARM_THRESHOLD=95

# === Alert Cooldown ===
# Minimum hours between repeat alerts of the same level
ALERT_COOLDOWN_HOURS=4
